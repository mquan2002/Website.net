@model Final.net.Models.User

@{
    ViewData["Title"] = "Details";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";

}

<h1>Chi tiết người dùng</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.UserName)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.UserName)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Email)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Email)
        </dd>
        

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Address)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Address)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Phone)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Phone)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.CreateOn)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.CreateOn)
        </dd>
    </dl>
</div>
<div>
    <button class="btn btn-primary">
        <a class="text-white text-decoration-none" asp-action="Edit" asp-action="Edit" asp-route-id="@Model?.UserId">Chỉnh sửa</a>
    </button>
    |
    <button class="btn btn-secondary ">
        <a class="text-white text-decoration-none" asp-action="Index">Quay về danh sách</a>
    </button>
    
</div>
