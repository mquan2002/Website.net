@model IEnumerable<Final.net.Models.User>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<h1>Quản lý Người dùng</h1>

<div class="mt-3 mb-3">
    <button class="btn btn-primary">
        <a class="text-decoration-none text-white" asp-action="Create">Tạo mới</a>
    </button>
</div>
<div class="container">
    <table class="table  table-striped-columns table-hover table-borderless">
        <thead>
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.UserId)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.UserName)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Email)
                </th>
             
                <th>
                    @Html.DisplayNameFor(model => model.Address)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Phone)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.CreateOn)
                </th>

                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.UserId)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.UserName)
                    </td> <td>
                        @Html.DisplayFor(modelItem => item.Email)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Address)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Phone)
                    </td><td>
                        @Html.DisplayFor(modelItem => item.CreateOn)
                    </td>
                   


                    <td>
                        <a class="text-decoration-none " asp-action="Edit" asp-route-id="@item.UserId">Chỉnh sửa</a> |
                        <a class="text-decoration-none text-black" asp-action="Details" asp-route-id="@item.UserId">Chi tiết</a> |
                        <a class="text-decoration-none text-danger" asp-action="Delete" asp-route-id="@item.UserId">Xoá</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
