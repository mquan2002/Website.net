@model Final.net.Models.Payment

@{
    ViewData["Title"] = "Details";
}

<h1>Chi tiết</h1>

<div>
    <h4>Phương thức thanht toán</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Method)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Method)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.PaymentDate)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.PaymentDate)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.AmountPaid)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.AmountPaid)
        </dd>
    </dl>
</div>
<div>
    <button class="btn btn-primary">
        <a class="text-white text-decoration-none" asp-action="Edit" asp-route-id="@Model?.PaymentId">Chỉnh sửa</a>
    </button>
    |
    <button class="btn btn-secondary ">
        <a class="text-white text-decoration-none" asp-action="Index">Quay về danh sách</a>

    </button>
</div>
