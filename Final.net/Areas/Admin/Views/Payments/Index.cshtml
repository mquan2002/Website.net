@model IEnumerable<Final.net.Models.Payment>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";

}

<h1>Quản lý phương thức thanh toán</h1>

<div class="mt-3 mb-3">
    <button class="btn btn-primary">
        <a class="text-decoration-none text-white" asp-action="Create">Tạo mới</a>
    </button>
</div>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.PaymentId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Method)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PaymentDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.AmountPaid)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.PaymentId)
                </td> <td>
                    @Html.DisplayFor(modelItem => item.Method)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.PaymentDate)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.AmountPaid)
                </td>
                <td>
                    <a class="text-decoration-none " asp-action="Edit" asp-route-id="@item.PaymentId">Chỉnh sửa</a> |
                    <a class="text-decoration-none text-black" asp-action="Details" asp-route-id="@item.PaymentId">Chi tiết</a> |
                    <a class="text-decoration-none text-danger" asp-action="Delete" asp-route-id="@item.PaymentId">Xoá</a>
                </td>
            </tr>
        }
    </tbody>
</table>
